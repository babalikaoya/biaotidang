{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(claude --)",
      "Bash(npm install *)",
      "Bash(npx next *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/)",
      "Bash(curl -s -o /dev/null -w '%{http_code}' http://localhost:3000/favorites)",
      "Bash(echo \"Favorites: $\\(curl -s -o /dev/null -w '%{http_code}' http://localhost:3000/favorites\\)\")",
      "Bash(curl -s -o /dev/null -w '%{http_code}' http://localhost:3000/history)",
      "Bash(echo \"History: $\\(curl -s -o /dev/null -w '%{http_code}' http://localhost:3000/history\\)\")",
      "Bash(curl -s -o /dev/null -w '%{http_code}' -X POST http://localhost:3000/api/generate-hooks -H 'Content-Type: application/json' -d '{}')",
      "Bash(pkill -f \"next dev\")",
      "Bash(gh --version)",
      "Bash(vercel --version)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ]
  }
}
